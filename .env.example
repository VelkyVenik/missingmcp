# Required: encryption key for stored account credentials/tokens (>=32 chars).
# Generate a real random value before deploying — the app refuses to start with this placeholder:
#   openssl rand -base64 48
GATEWAY_SECRET=change-me-to-a-long-random-string-min-32-chars
# Public HTTPS URL of the gateway — your Railway domain or the domain nginx
# serves (used in OAuth metadata + redirects)
PUBLIC_URL=https://gateway.example.com
# Pin the garmin_mcp worker to a reviewed commit (supply-chain). Bumping it is a
# deliberate, reviewed action — the worker runs with users' decrypted Garmin tokens.
GARMIN_MCP_REF=2974244bfda1595b00836b3f942f579ec2d6f7d6
# Worker command (defaults to bare `garmin-mcp`, installed globally in the Docker
# image). Override for local runs where garmin-mcp isn't on PATH:
#   GARMIN_MCP_CMD=uvx --python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp garmin-mcp
# GARMIN_MCP_CMD=garmin-mcp
# Logging: set a file path to tee structured + stdlib logs there (optional).
# GATEWAY_LOG_FILE=/data/gateway.log
# Log level: debug|info|warning|error|critical (default info). debug captures
# garminconnect / urllib3 / uvicorn internals — verbose, avoid in production.
# GATEWAY_LOG_LEVEL=info
# Optional tuning
PORT=8080
DATA_DIR=/data
WORKER_PORT_START=9000
WORKER_PORT_END=9099
WORKER_IDLE_TTL=900
MAX_WORKERS=10
# Access-token lifetime in days; after this the user re-authenticates in Claude.
# Set 0 to disable expiry. Default 90.
ACCESS_TOKEN_TTL_DAYS=90
OPERATOR_NAME=Your Name
OPERATOR_EMAIL=you@example.com

# Off-box SQLite backups to an S3-compatible bucket (e.g. `railway bucket create`).
# Disabled unless all four credentials are set. See README -> Backups.
# BACKUP_S3_ENDPOINT=https://t3.storageapi.dev
# BACKUP_S3_BUCKET=your-bucket-name
# BACKUP_S3_ACCESS_KEY=...
# BACKUP_S3_SECRET_KEY=...
# BACKUP_S3_REGION=auto
# BACKUP_INTERVAL_HOURS=6
